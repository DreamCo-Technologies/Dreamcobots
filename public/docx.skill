## Lists

```js
const { Paragraph, TextRun, NumberingType } = require('docx');

// Bullet list - define numbering in Document constructor
const doc = new Document({
  numbering: {
    config: [
      {
        reference: 'my-bullet-list',
        levels: [
          {
            level: 0,
            format: LevelFormat.BULLET,
            text: '\u2022',
            alignment: AlignmentType.LEFT,
            style: {
              paragraph: {
                indent: { left: 720, hanging: 360 },
              },
            },
          },
          {
            level: 1,
            format: LevelFormat.BULLET,
            text: '\u25E6',
            alignment: AlignmentType.LEFT,
            style: {
              paragraph: {
                indent: { left: 1440, hanging: 360 },
              },
            },
          },
        ],
      },
      {
        reference: 'my-ordered-list',
        levels: [
          {
            level: 0,
            format: LevelFormat.DECIMAL,
            text: '%1.',
            alignment: AlignmentType.LEFT,
            style: {
              paragraph: {
                indent: { left: 720, hanging: 360 },
              },
            },
          },
        ],
      },
    ],
  },
  sections: [{
    children: [
      new Paragraph({
        text: 'Bullet item 1',
        numbering: { reference: 'my-bullet-list', level: 0 },
      }),
      new Paragraph({
        text: 'Nested bullet item',
        numbering: { reference: 'my-bullet-list', level: 1 },
      }),
      new Paragraph({
        text: 'Ordered item 1',
        numbering: { reference: 'my-ordered-list', level: 0 },
      }),
    ],
  }],
});
```

