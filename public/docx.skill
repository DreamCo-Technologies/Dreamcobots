```js
// Alignment
AlignmentType.LEFT
AlignmentType.CENTER
AlignmentType.RIGHT
AlignmentType.JUSTIFIED

// Heading levels
HeadingLevel.TITLE
HeadingLevel.HEADING_1 ... HeadingLevel.HEADING_6

// Border styles
BorderStyle.SINGLE
BorderStyle.DOUBLE
BorderStyle.DASHED
BorderStyle.DOTTED
BorderStyle.THICK

// Underline types
UnderlineType.SINGLE
UnderlineType.DOUBLE
UnderlineType.DASH
UnderlineType.WAVE

// Width types
WidthType.AUTO
WidthType.PERCENTAGE
WidthType.DXA         // twips

// Page orientation
PageOrientation.PORTRAIT
PageOrientation.LANDSCAPE

// Vertical alignment (table cell)
VerticalAlign.TOP
VerticalAlign.CENTER
VerticalAlign.BOTTOM
```

