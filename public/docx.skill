## Custom Styles

```js
const doc = new Document({
  styles: {
    paragraphStyles: [
      {
        id: 'CustomHeading',
        name: 'Custom Heading',
        basedOn: 'Normal',
        next: 'Normal',
        quickFormat: true,
        run: {
          size: 36,
          bold: true,
          color: '1F4E79',
          font: 'Calibri',
        },
        paragraph: {
          spacing: { before: 240, after: 120 },
        },
      },
      {
        id: 'BodyText',
        name: 'Body Text',
        basedOn: 'Normal',
        run: {
          size: 24,
          font: 'Times New Roman',
        },
        paragraph: {
          spacing: { line: 360, before: 0, after: 160 },
        },
      },
    ],
    characterStyles: [
      {
        id: 'Emphasis',
        name: 'Emphasis',
        basedOn: 'DefaultParagraphFont',
        run: {
          italics: true,
          color: '1F4E79',
        },
      },
    ],
  },
  sections: [{
    children: [
      new Paragraph({
        text: 'Custom Heading Text',
        style: 'CustomHeading',
      }),
      new Paragraph({
        text: 'Body text using custom style',
        style: 'BodyText',
      }),
    ],
  }],
});
```

---

## Page Breaks & Section Breaks

```js
const { Paragraph, PageBreak } = require('docx');

// Page break in paragraph
new Paragraph({
  children: [new PageBreak()],
})

// Or use pageBreakBefore property
new Paragraph({
  text: 'This starts on a new page',
  pageBreakBefore: true,
})
```

