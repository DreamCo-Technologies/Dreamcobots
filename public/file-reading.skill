## YAML

```js
const YAML = require('yaml');
const fs = require('fs');

// Parse YAML
const data = YAML.parse(fs.readFileSync('config.yml', 'utf8'));

// Multiple YAML documents (---) in one file
const docs = YAML.parseAllDocuments(fs.readFileSync('multi.yml', 'utf8'));
const objects = docs.map((d) => d.toJSON());

// Stringify
const yaml = YAML.stringify(data, { indent: 2 });
```

