# file-reading Skill — Reading Various File Formats

## Libraries

```bash
npm install csv-parse    # CSV/TSV parsing
npm install fast-csv     # fast CSV streaming
npm install yaml         # YAML parsing
npm install xml2js       # XML to JSON
npm install @iarna/toml  # TOML parsing
npm install ini          # INI/config file parsing
npm install iconv-lite   # character encoding
npm install chardet      # encoding detection
```

---

## JSON

```js
const fs = require('fs');

// Synchronous
const data = JSON.parse(fs.readFileSync('data.json', 'utf8'));

// Async
const data = JSON.parse(await fs.promises.readFile('data.json', 'utf8'));

// With error handling
function readJson(filePath) {
  try {
    return JSON.parse(fs.readFileSync(filePath, 'utf8'));
  } catch (err) {
    if (err.code === 'ENOENT') throw new Error(`File not found: ${filePath}`);
    if (err instanceof SyntaxError) throw new Error(`Invalid JSON in ${filePath}: ${err.message}`);
    throw err;
  }
}

// JSONL (newline-delimited JSON)
const lines = fs.readFileSync('data.jsonl', 'utf8').split('\n').filter(Boolean);
const records = lines.map((l) => JSON.parse(l));
```

---

## CSV

### csv-parse

```js
const { parse } = require('csv-parse');
const fs = require('fs');

// Parse full file to array
async function parseCsv(filePath) {
  const content = fs.readFileSync(filePath, 'utf8');
  return new Promise((resolve, reject) => {
    parse(content, {
      columns: true,         // first row = headers
      skip_empty_lines: true,
      trim: true,
      cast: true,            // auto-cast numbers/booleans
      delimiter: ',',
      quote: '"',
      escape: '\\',
      comment: '#',
      relax_column_count: true,
    }, (err, records) => {
      if (err) reject(err); else resolve(records);
    });
  });
}

// Streaming (for large files)
async function streamCsv(filePath, onRow) {
  const parser = fs.createReadStream(filePath)
    .pipe(parse({ columns: true, trim: true, cast: true }));

  for await (const record of parser) {
    await onRow(record);
  }
}
```

### TSV (Tab-separated)

```js
parse(content, { delimiter: '\t', columns: true })
```

---

## XML

### xml2js

```js
const xml2js = require('xml2js');
const fs = require('fs');

// Parse XML to JSON object
async function parseXml(filePath) {
  const xml = fs.readFileSync(filePath, 'utf8');
  return xml2js.parseStringPromise(xml, {
    explicitArray: false,    // don't wrap single values in arrays
    mergeAttrs: true,        // merge attributes into parent object
    trim: true,
    normalize: true,
    ignoreAttrs: false,
    attrNameProcessors: [(name) => name.toLowerCase()],
    tagNameProcessors: [(name) => name.toLowerCase()],
  });
}

// Build XML from JS object
function buildXml(jsObj) {
  const builder = new xml2js.Builder({
    rootName: 'root',
    headless: false,
    renderOpts: { pretty: true, indent: '  ' },
  });
  return builder.buildObject(jsObj);
}
```

