## Plain Text / Markdown

```js
const fs = require('fs');

// Read lines
const lines = fs.readFileSync('notes.txt', 'utf8').split('\n');

// Stream lines (large files)
const readline = require('readline');
async function readLines(filePath) {
  const rl = readline.createInterface({
    input: fs.createReadStream(filePath),
    crlfDelay: Infinity,
  });
  const lines = [];
  for await (const line of rl) {
    lines.push(line);
  }
  return lines;
}

// Extract headings from Markdown
function extractMarkdownHeadings(content) {
  const headings = [];
  const re = /^(#{1,6})\s+(.+)$/gm;
  let match;
  while ((match = re.exec(content)) !== null) {
    headings.push({ level: match[1].length, text: match[2].trim() });
  }
  return headings;
}
```

---

## Binary Files

```js
const fs = require('fs');

// Read as Buffer
const buf = fs.readFileSync('file.bin');

// Read specific bytes
const fd = fs.openSync('file.bin', 'r');
const chunk = Buffer.alloc(16);
fs.readSync(fd, chunk, 0, 16, 0);  // read 16 bytes at offset 0
fs.closeSync(fd);

// Check magic bytes / file signatures
function getFileType(filePath) {
  const buf = Buffer.alloc(8);
  const fd = fs.openSync(filePath, 'r');
  fs.readSync(fd, buf, 0, 8, 0);
  fs.closeSync(fd);

  if (buf[0] === 0x25 && buf[1] === 0x50) return 'PDF';     // %PDF
  if (buf[0] === 0x89 && buf[1] === 0x50) return 'PNG';
  if (buf[0] === 0xFF && buf[1] === 0xD8) return 'JPEG';
  if (buf[0] === 0x50 && buf[1] === 0x4B) return 'ZIP/Office';
  if (buf[0] === 0xD0 && buf[1] === 0xCF) return 'OLE/Legacy Office';
  return 'Unknown';
}
```

