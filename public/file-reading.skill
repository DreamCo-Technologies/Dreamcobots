## Streaming Large Files

```js
const fs = require('fs');
const readline = require('readline');
const { Transform } = require('stream');

// Process line-by-line without loading into memory
async function processLargeFile(filePath, processor) {
  const rl = readline.createInterface({
    input: fs.createReadStream(filePath, { encoding: 'utf8' }),
    crlfDelay: Infinity,
  });

  let lineNum = 0;
  for await (const line of rl) {
    lineNum++;
    await processor(line, lineNum);
  }
  return lineNum;
}

// Usage
await processLargeFile('huge.csv', async (line, n) => {
  if (n === 1) return;  // skip header
  const fields = line.split(',');
  // process fields...
});
```

---

## Error Handling Patterns

```js
async function safeReadFile(filePath) {
  try {
    const stat = await fs.promises.stat(filePath);
    if (!stat.isFile()) throw new Error(`Not a file: ${filePath}`);
    if (stat.size > 100 * 1024 * 1024) console.warn(`Large file: ${(stat.size / 1024 / 1024).toFixed(1)} MB`);
    return await fs.promises.readFile(filePath, 'utf8');
  } catch (err) {
    if (err.code === 'ENOENT') throw new Error(`File not found: ${filePath}`);
    if (err.code === 'EACCES') throw new Error(`Permission denied: ${filePath}`);
    throw err;
  }
}
```

---

## Quick Format Detection

```js
const path = require('path');

function getParser(filePath) {
  const ext = path.extname(filePath).toLowerCase();
  const parsers = {
    '.json': (s) => JSON.parse(s),
    '.yaml': (s) => require('yaml').parse(s),
    '.yml':  (s) => require('yaml').parse(s),
    '.toml': (s) => require('@iarna/toml').parse(s),
    '.ini':  (s) => require('ini').parse(s),
    '.csv':  (s) => require('csv-parse/sync').parse(s, { columns: true, cast: true }),
    '.tsv':  (s) => require('csv-parse/sync').parse(s, { columns: true, delimiter: '\t' }),
    '.xml':  async (s) => require('xml2js').parseStringPromise(s, { explicitArray: false }),
  };
  return parsers[ext] || ((s) => s);
}
```
