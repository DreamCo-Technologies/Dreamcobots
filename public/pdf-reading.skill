## pdfjs-dist — Per-Page Text with Positions

```js
const pdfjsLib = require('pdfjs-dist/legacy/build/pdf');

async function extractByPage(pdfPath) {
  const loadingTask = pdfjsLib.getDocument(pdfPath);
  const pdfDocument = await loadingTask.promise;

  console.log(`Total pages: ${pdfDocument.numPages}`);

  for (let pageNum = 1; pageNum <= pdfDocument.numPages; pageNum++) {
    const page = await pdfDocument.getPage(pageNum);
    const textContent = await page.getTextContent();

    const pageText = textContent.items
      .map((item) => item.str)
      .join(' ');

    console.log(`\n--- Page ${pageNum} ---`);
    console.log(pageText);
  }
}
```

### Text Item Structure

Each `item` in `textContent.items`:

```js
{
  str: 'Hello',              // text content
  dir: 'ltr',               // text direction
  transform: [sx, shy, shx, sy, tx, ty],  // transformation matrix
  width: 45.6,              // text width in user units
  height: 12.0,             // text height
  fontName: 'g_d0_f1',      // internal font name
  hasEOL: false,            // end of line marker
}

// Position extraction
const x = item.transform[4];   // x position
const y = item.transform[5];   // y position (from bottom)
const fontSize = item.height;
```

### Grouping Text by Lines

```js
function groupByLines(textContent, lineThreshold = 5) {
  const items = textContent.items.slice().sort((a, b) => {
    const yDiff = b.transform[5] - a.transform[5];
    return Math.abs(yDiff) > lineThreshold ? yDiff : a.transform[4] - b.transform[4];
  });

  const lines = [];
  let currentLine = null;
  let currentY = null;

  for (const item of items) {
    const y = item.transform[5];
    if (currentY === null || Math.abs(y - currentY) > lineThreshold) {
      if (currentLine) lines.push(currentLine);
      currentLine = { y, items: [item] };
      currentY = y;
    } else {
      currentLine.items.push(item);
    }
  }
  if (currentLine) lines.push(currentLine);
  return lines.map((l) => l.items.map((i) => i.str).join(' '));
}
```

### Getting Metadata via pdfjs

```js
const metadata = await pdfDocument.getMetadata();
console.log('Info:', metadata.info);
console.log('Metadata:', metadata.metadata?.getAll());
```

### Getting Annotations

```js
const page = await pdfDocument.getPage(1);
const annotations = await page.getAnnotations();

annotations.forEach((ann) => {
  console.log('Type:', ann.subtype);
  if (ann.subtype === 'Link') {
    console.log('URL:', ann.url);
    console.log('Rect:', ann.rect);
  }
  if (ann.subtype === 'Widget') {
    console.log('Field:', ann.fieldName, '=', ann.fieldValue);
  }
});
```

