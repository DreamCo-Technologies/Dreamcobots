## pdf-lib — Reading Metadata & Structure

```js
const { PDFDocument } = require('pdf-lib');
const fs = require('fs');

async function readPdfMetadata(pdfPath) {
  const pdfDoc = await PDFDocument.load(fs.readFileSync(pdfPath));

  return {
    title:        pdfDoc.getTitle(),
    author:       pdfDoc.getAuthor(),
    subject:      pdfDoc.getSubject(),
    keywords:     pdfDoc.getKeywords(),
    producer:     pdfDoc.getProducer(),
    creator:      pdfDoc.getCreator(),
    creationDate: pdfDoc.getCreationDate(),
    modDate:      pdfDoc.getModificationDate(),
    pageCount:    pdfDoc.getPageCount(),
    pages: pdfDoc.getPages().map((p, i) => ({
      index: i,
      width:    p.getWidth(),
      height:   p.getHeight(),
      rotation: p.getRotation().angle,
    })),
  };
}
```

### Reading Form Fields

```js
async function getFormData(pdfPath) {
  const pdfDoc = await PDFDocument.load(fs.readFileSync(pdfPath));
  const form = pdfDoc.getForm();
  const result = {};

  form.getFields().forEach((field) => {
    const name = field.getName();
    const type = field.constructor.name;
    try {
      switch (type) {
        case 'PDFTextField':    result[name] = field.getText(); break;
        case 'PDFCheckBox':     result[name] = field.isChecked(); break;
        case 'PDFDropdown':     result[name] = field.getSelected(); break;
        case 'PDFRadioGroup':   result[name] = field.getSelected(); break;
        case 'PDFOptionList':   result[name] = field.getSelected(); break;
        default:                result[name] = `[${type}]`;
      }
    } catch {
      result[name] = null;
    }
  });
  return result;
}
```

