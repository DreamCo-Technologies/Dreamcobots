## pptxgenjs Complete API Reference

### Installation & Setup

```bash
npm install pptxgenjs
```

```js
const PptxGenJS = require('pptxgenjs');
const pptx = new PptxGenJS();

// Global settings
pptx.layout = 'LAYOUT_16x9';  // 'LAYOUT_4x3'|'LAYOUT_16x9'|'LAYOUT_16x10'|'LAYOUT_WIDE'|custom
pptx.subject = 'Quarterly Report';
pptx.author = 'John Doe';
pptx.company = 'ACME Corp';
pptx.revision = '1';
pptx.title = 'Q4 2024 Results';

// Custom layout
pptx.defineLayout({ name: 'A3', width: 16.54, height: 11.69 });
pptx.layout = 'A3';
```

### Slide Masters & Layouts

```js
// Define slide master
pptx.defineSlideMaster({
  title: 'MASTER_SLIDE',
  background: { color: 'FFFFFF' },
  objects: [
    { rect: { x: 0, y: 7.0, w: '100%', h: 0.75, fill: { color: '003366' } } },
    {
      text: {
        text: 'CONFIDENTIAL',
        options: {
          x: 0, y: 7.0, w: '100%', h: 0.75,
          align: 'center', valign: 'middle',
          color: 'FFFFFF', fontSize: 10,
        }
      }
    },
    {
      image: {
        x: 0.5, y: 0.25, w: 1.5, h: 0.5,
        path: './logo.png',
      }
    },
  ],
  slideNumber: { x: '90%', y: 7.1, color: 'FFFFFF', fontSize: 9, fontFace: 'Arial' },
  margin: [0.5, 0.25, 1.25, 0.5],
});

// Add slide using master
const slide = pptx.addSlide({ masterName: 'MASTER_SLIDE' });
```

### Adding Slides

```js
// Basic slide
const slide1 = pptx.addSlide();

// Slide with master
const slide2 = pptx.addSlide({ masterName: 'MASTER_SLIDE' });

// Slide with background
const slide3 = pptx.addSlide();
slide3.background = { color: 'F5F5F5' };
slide3.background = { path: './bg.jpg' };
slide3.background = { data: 'data:image/png;base64,...' };

// Hidden slide
const slide4 = pptx.addSlide();
slide4.hidden = true;

// Slide number display
pptx.slides.forEach((slide, i) => {
  slide.addText(`Slide ${i + 1}`, {
    x: '90%', y: '95%', w: '8%', h: '4%',
    fontSize: 9, color: '999999', align: 'right',
  });
});
```

### Text Elements

```js
// Simple text
slide.addText('Hello, World!', {
  x: 0.5, y: 0.5, w: 9, h: 1,
  fontFace: 'Arial',
  fontSize: 36,
  bold: true,
  italic: false,
  underline: { style: 'sng', color: '0000FF' },
  strike: false,
  color: '003366',
  fill: { color: 'FFFFCC' },
  transparency: 0,
  border: { pt: 1, color: '666666' },
  align: 'center',  // 'left'|'center'|'right'|'justify'
  valign: 'middle', // 'top'|'middle'|'bottom'
  wrap: true,
  autoFit: false,
  shrinkText: false,
  inset: 0.05,
  paraSpaceBefore: 6,
  paraSpaceAfter: 6,
  lineSpacingMultiple: 1.2,
  charSpacing: 1,
  rotate: 0,         // degrees
  shadow: {
    type: 'outer',
    color: '000000',
    opacity: 0.5,
    blur: 4,
    offset: 4,
    angle: 45,
  },
  hyperlink: {
    url: 'https://example.com',
    tooltip: 'Visit our site',
  },
  rtlMode: false,
  lang: 'en-US',
  placeholder: 'body',  // for master slide placeholders
});

// Multi-format text (text runs)
slide.addText([
  { text: 'Bold text ', options: { bold: true, color: 'FF0000' } },
  { text: 'and normal text ', options: { bold: false } },
  { text: '\n' },
  { text: 'New line with ', options: { fontSize: 18 } },
  { text: 'hyperlink', options: { hyperlink: { url: 'https://google.com' } } },
  { text: '\nBullet point', options: { bullet: true, indentLevel: 0 } },
  { text: '\nSub-bullet', options: { bullet: { type: 'number', indent: 30 }, indentLevel: 1 } },
], {
  x: 0.5, y: 1.5, w: 9, h: 5,
  fontSize: 16,
  fontFace: 'Calibri',
  color: '333333',
});
```

