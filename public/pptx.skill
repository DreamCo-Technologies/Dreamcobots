### Transitions and Animations

```js
// Slide transition
slide.transition = {
  type: 'fade',    // 'none'|'cut'|'fade'|'push'|'wipe'|'split'|'reveal'|'random_bars'|'shape'|'blinds'|'checker'|'comb'|'cover'|'dissolve'|'newsflash'|'pull'|'random'|'zoom'
  speed: 'medium', // 'slow'|'medium'|'fast'
  advAuto: '00:03:00',  // auto advance after 3 seconds
};

// Object animation (limited support)
slide.addText('Animated text', {
  x: 1, y: 1, w: 8, h: 1,
  fontSize: 24,
  animate: {
    type: 'appear',
    triggerType: 'onClick',
    delay: 500,
  }
});
```

### Media Embedding

```js
// Video from file
slide.addMedia({
  type: 'video',
  path: './videos/intro.mp4',
  x: 1, y: 1, w: 8, h: 4.5,
  cover: './images/video-thumbnail.jpg',
  autoPlay: false,
  loop: false,
  muted: false,
});

// Audio from URL
slide.addMedia({
  type: 'audio',
  link: 'https://example.com/audio.mp3',
  x: 0.5, y: 0.5, w: 1, h: 0.5,
  autoPlay: false,
  loop: false,
});

// Online video (YouTube embed)
slide.addMedia({
  type: 'online',
  link: 'https://www.youtube.com/embed/dQw4w9WgXcQ',
  x: 1, y: 1, w: 8, h: 4.5,
});
```

### Export Options

```js
// Save to file
await pptx.writeFile({ fileName: 'presentation.pptx' });

// Get as base64
const base64Data = await pptx.write({ outputType: 'base64' });

// Get as Blob (browser)
const blob = await pptx.write({ outputType: 'blob' });

// Get as Buffer (Node.js)
const buffer = await pptx.write({ outputType: 'nodebuffer' });

// Get as Uint8Array
const uint8 = await pptx.write({ outputType: 'uint8array' });

// Get as ArrayBuffer
const arrayBuffer = await pptx.write({ outputType: 'arraybuffer' });

// Callback style (older API)
pptx.save('my-presentation', (fileName) => {
  console.log(`Saved: ${fileName}`);
}, 'nodebuffer');
```

### Complete Presentation Example

```js
const PptxGenJS = require('pptxgenjs');

async function createQuarterlyReport(data) {
  const pptx = new PptxGenJS();
  pptx.layout = 'LAYOUT_16x9';
  pptx.title = 'Q4 2024 Quarterly Report';
  pptx.author = 'Analytics Team';

  // Define master
  pptx.defineSlideMaster({
    title: 'CORPORATE',
    background: { color: 'FFFFFF' },
    objects: [
      { rect: { x: 0, y: 0, w: '100%', h: 0.08, fill: { color: '003366' } } },
      { rect: { x: 0, y: 7.42, w: '100%', h: 0.08, fill: { color: '003366' } } },
      {
        text: {
          text: data.companyName,
          options: {
            x: 0.4, y: 7.4, w: 5, h: 0.1,
            fontSize: 8, color: 'FFFFFF', bold: false, align: 'left',
          }
        }
      },
    ],
    slideNumber: { x: '92%', y: 7.38, color: 'CCCCCC', fontSize: 8 },
  });

  // Title slide
  const titleSlide = pptx.addSlide({ masterName: 'CORPORATE' });
  titleSlide.addShape(pptx.shapes.RECTANGLE, {
    x: 0, y: 2.5, w: '100%', h: 2.5,
    fill: { color: '003366' },
    line: { width: 0 },
  });
  titleSlide.addText(data.title, {
    x: 0.5, y: 2.7, w: 9, h: 1.2,
    fontFace: 'Calibri Light',
    fontSize: 40,
    bold: false,
    color: 'FFFFFF',
    align: 'center',
  });
  titleSlide.addText(`Q4 ${data.year} | ${data.presenter}`, {
    x: 0.5, y: 3.9, w: 9, h: 0.6,
    fontFace: 'Calibri',
    fontSize: 18,
    color: 'CCCCCC',
    align: 'center',
  });

  // Executive Summary slide
  const summarySlide = pptx.addSlide({ masterName: 'CORPORATE' });
  summarySlide.addText('Executive Summary', {
    x: 0.4, y: 0.2, w: 9.2, h: 0.6,
    fontFace: 'Calibri Light',
    fontSize: 28,
    color: '003366',
    bold: false,
  });

  // KPI boxes
  const kpis = [
    { label: 'Revenue', value: '$' + (data.revenue / 1e6).toFixed(1) + 'M', change: '+12.5%', positive: true },
    { label: 'Net Income', value: '$' + (data.netIncome / 1e6).toFixed(1) + 'M', change: '+8.3%', positive: true },
    { label: 'EBITDA', value: (data.ebitdaMargin * 100).toFixed(1) + '%', change: '+1.2pp', positive: true },
    { label: 'Customers', value: data.customers.toLocaleString(), change: '-2.1%', positive: false },
  ];

  kpis.forEach((kpi, i) => {
    const x = 0.4 + i * 2.35;
    summarySlide.addShape(pptx.shapes.RECTANGLE, {
      x, y: 1.0, w: 2.2, h: 2.5,
      fill: { color: kpi.positive ? 'E8F4FD' : 'FDE8E8' },
      line: { color: kpi.positive ? '2E75B6' : 'C00000', width: 1 },
    });
    summarySlide.addText(kpi.label, { x, y: 1.1, w: 2.2, h: 0.4, fontSize: 11, color: '666666', align: 'center' });
    summarySlide.addText(kpi.value, { x, y: 1.5, w: 2.2, h: 0.8, fontSize: 22, bold: true, color: '003366', align: 'center' });
    summarySlide.addText(kpi.change, {
      x, y: 2.3, w: 2.2, h: 0.4,
      fontSize: 14, bold: true,
      color: kpi.positive ? '375623' : '9C0006',
      align: 'center'
    });
  });

  // Revenue chart slide
  const chartSlide = pptx.addSlide({ masterName: 'CORPORATE' });
  chartSlide.addText('Revenue Trend', { x: 0.4, y: 0.2, w: 9.2, h: 0.6, fontSize: 28, color: '003366', fontFace: 'Calibri Light' });
  chartSlide.addChart(pptx.charts.LINE, [
    {
      name: 'Revenue',
      labels: data.months,
      values: data.monthlyRevenue,
    },
    {
      name: 'Target',
      labels: data.months,
      values: data.monthlyTarget,
    }
  ], {
    x: 0.4, y: 1.0, w: 9.2, h: 5.8,
    showTitle: false,
    showLegend: true,
    legendPos: 'b',
    chartColors: ['2E75B6', 'ED7D31'],
    lineSmooth: true,
    lineDataSymbol: 'circle',
    valAxisNumFmt: '"$"#,##0',
    valAxisTitle: 'Monthly Revenue',
    catAxisTitle: 'Month',
    gridLineMajorClr: 'EEEEEE',
  });

  await pptx.writeFile({ fileName: 'quarterly-report.pptx' });
  return 'quarterly-report.pptx';
}
```

### Color Schemes and Themes

```js
// Theme colors for consistent presentations
const THEME_COLORS = {
  primary:    '003366',  // dark blue
  secondary:  '2E75B6',  // medium blue
  accent1:    'ED7D31',  // orange
  accent2:    'A9D18E',  // green
  accent3:    'FFC000',  // yellow
  accent4:    'FF0000',  // red
  dark1:      '000000',  // black
  dark2:      '333333',  // dark gray
  light1:     'FFFFFF',  // white
  light2:     'F5F5F5',  // off-white
  text:       '363636',  // near black
  textLight:  '666666',  // medium gray
  border:     'CCCCCC',  // light gray
  success:    '375623',  // dark green
  warning:    'FF6B00',  // orange
  error:      '9C0006',  // dark red
  info:       '0070C0',  // blue
  successBg:  'C6EFCE',  // light green
  warningBg:  'FFEB9C',  // light yellow
  errorBg:    'FFC7CE',  // light red
  infoBg:     'DDEBF7',  // light blue
};

// Apply consistent styles across multiple slides
function applyTheme(pptx, slides) {
  slides.forEach(slide => {
    slide.background = { color: THEME_COLORS.light1 };
  });
}
```

### Troubleshooting

**Issue: Images not loading from URL**
```js
// Use local path or base64 instead
const axios = require('axios');
const response = await axios.get(imageUrl, { responseType: 'arraybuffer' });
const base64 = Buffer.from(response.data).toString('base64');
const ext = imageUrl.split('.').pop();
slide.addImage({ data: `data:image/${ext};base64,${base64}`, x, y, w, h });
```

**Issue: Large file size**
```js
// Compress images before embedding
const sharp = require('sharp');
const compressed = await sharp(imagePath).resize(800).jpeg({ quality: 80 }).toBuffer();
const b64 = compressed.toString('base64');
slide.addImage({ data: `data:image/jpeg;base64,${b64}`, x, y, w, h });
```

**Issue: Text not wrapping**
```js
// Ensure wrap is true and dimensions allow wrapping
slide.addText('Long text content...', {
  x: 0.5, y: 0.5, w: 5, h: 3,  // specify w and h
  wrap: true,
  autoFit: false,
});
```

**Issue: Charts with too many data points**
```js
// Aggregate data before charting
function aggregateByMonth(data) {
  return data.reduce((acc, item) => {
    const month = item.date.toISOString().slice(0, 7);
    if (!acc[month]) acc[month] = 0;
    acc[month] += item.value;
    return acc;
  }, {});
}
```


---

## pptxgenjs Complete API Reference

### Installation & Setup

```bash
npm install pptxgenjs
```

```js
const PptxGenJS = require('pptxgenjs');
const pptx = new PptxGenJS();

// Global settings
pptx.layout = 'LAYOUT_16x9';  // 'LAYOUT_4x3'|'LAYOUT_16x9'|'LAYOUT_16x10'|'LAYOUT_WIDE'|custom
pptx.subject = 'Quarterly Report';
pptx.author = 'John Doe';
pptx.company = 'ACME Corp';
pptx.revision = '1';
pptx.title = 'Q4 2024 Results';

// Custom layout
pptx.defineLayout({ name: 'A3', width: 16.54, height: 11.69 });
pptx.layout = 'A3';
```

### Slide Masters & Layouts

```js
// Define slide master
pptx.defineSlideMaster({
  title: 'MASTER_SLIDE',
  background: { color: 'FFFFFF' },
  objects: [
    { rect: { x: 0, y: 7.0, w: '100%', h: 0.75, fill: { color: '003366' } } },
    {
      text: {
        text: 'CONFIDENTIAL',
        options: {
          x: 0, y: 7.0, w: '100%', h: 0.75,
          align: 'center', valign: 'middle',
          color: 'FFFFFF', fontSize: 10,
        }
      }
    },
    {
      image: {
        x: 0.5, y: 0.25, w: 1.5, h: 0.5,
        path: './logo.png',
      }
    },
  ],
  slideNumber: { x: '90%', y: 7.1, color: 'FFFFFF', fontSize: 9, fontFace: 'Arial' },
  margin: [0.5, 0.25, 1.25, 0.5],
});

// Add slide using master
const slide = pptx.addSlide({ masterName: 'MASTER_SLIDE' });
```

### Adding Slides

```js
// Basic slide
const slide1 = pptx.addSlide();

// Slide with master
const slide2 = pptx.addSlide({ masterName: 'MASTER_SLIDE' });

// Slide with background
const slide3 = pptx.addSlide();
slide3.background = { color: 'F5F5F5' };
slide3.background = { path: './bg.jpg' };
slide3.background = { data: 'data:image/png;base64,...' };

// Hidden slide
const slide4 = pptx.addSlide();
slide4.hidden = true;

// Slide number display
pptx.slides.forEach((slide, i) => {
  slide.addText(`Slide ${i + 1}`, {
    x: '90%', y: '95%', w: '8%', h: '4%',
    fontSize: 9, color: '999999', align: 'right',
  });
});
```

### Text Elements

```js
// Simple text
slide.addText('Hello, World!', {
  x: 0.5, y: 0.5, w: 9, h: 1,
  fontFace: 'Arial',
  fontSize: 36,
  bold: true,
  italic: false,
  underline: { style: 'sng', color: '0000FF' },
  strike: false,
  color: '003366',
  fill: { color: 'FFFFCC' },
  transparency: 0,
  border: { pt: 1, color: '666666' },
  align: 'center',  // 'left'|'center'|'right'|'justify'
  valign: 'middle', // 'top'|'middle'|'bottom'
  wrap: true,
  autoFit: false,
  shrinkText: false,
  inset: 0.05,
  paraSpaceBefore: 6,
  paraSpaceAfter: 6,
  lineSpacingMultiple: 1.2,
  charSpacing: 1,
  rotate: 0,         // degrees
  shadow: {
    type: 'outer',
    color: '000000',
    opacity: 0.5,
    blur: 4,
    offset: 4,
    angle: 45,
  },
  hyperlink: {
    url: 'https://example.com',
    tooltip: 'Visit our site',
  },
  rtlMode: false,
  lang: 'en-US',
  placeholder: 'body',  // for master slide placeholders
});

// Multi-format text (text runs)
slide.addText([
  { text: 'Bold text ', options: { bold: true, color: 'FF0000' } },
  { text: 'and normal text ', options: { bold: false } },
  { text: '\n' },
  { text: 'New line with ', options: { fontSize: 18 } },
  { text: 'hyperlink', options: { hyperlink: { url: 'https://google.com' } } },
  { text: '\nBullet point', options: { bullet: true, indentLevel: 0 } },
  { text: '\nSub-bullet', options: { bullet: { type: 'number', indent: 30 }, indentLevel: 1 } },
], {
  x: 0.5, y: 1.5, w: 9, h: 5,
  fontSize: 16,
  fontFace: 'Calibri',
  color: '333333',
});
```

### Shape Elements

```js
// Rectangle
slide.addShape(pptx.shapes.RECTANGLE, {
  x: 1, y: 1, w: 3, h: 2,
  fill: { color: '4472C4' },
  line: { color: '2F5597', width: 2, dashType: 'solid' },
  shadow: { type: 'outer', color: '000000', opacity: 0.3, blur: 3, offset: 3, angle: 45 },
  transparency: 0,
  rotate: 0,
});

// All shape types
const shapes = [
  pptx.shapes.RECTANGLE,
  pptx.shapes.ROUNDED_RECTANGLE,
  pptx.shapes.OVAL,
  pptx.shapes.TRIANGLE,
  pptx.shapes.RIGHT_TRIANGLE,
  pptx.shapes.PARALLELOGRAM,
  pptx.shapes.TRAPEZOID,
  pptx.shapes.DIAMOND,
  pptx.shapes.PENTAGON,
  pptx.shapes.HEXAGON,
  pptx.shapes.HEPTAGON,
  pptx.shapes.OCTAGON,
  pptx.shapes.DECAGON,
  pptx.shapes.STAR_4,
  pptx.shapes.STAR_5,
  pptx.shapes.STAR_6,
  pptx.shapes.STAR_7,
  pptx.shapes.STAR_8,
  pptx.shapes.STAR_10,
  pptx.shapes.STAR_12,
  pptx.shapes.STAR_16,
  pptx.shapes.STAR_24,
  pptx.shapes.STAR_32,
  pptx.shapes.ARROW_RIGHT,
  pptx.shapes.ARROW_LEFT,
  pptx.shapes.ARROW_UP,
  pptx.shapes.ARROW_DOWN,
  pptx.shapes.ARROW_LEFT_RIGHT,
  pptx.shapes.ARROW_UP_DOWN,
  pptx.shapes.CALLOUT_1,
  pptx.shapes.CALLOUT_2,
  pptx.shapes.CALLOUT_3,
  pptx.shapes.LINE,
  pptx.shapes.LINE_ARROW,
  pptx.shapes.LINE_ARROWS,
  pptx.shapes.FLOW_CHART_PROCESS,
  pptx.shapes.FLOW_CHART_DECISION,
  pptx.shapes.FLOW_CHART_DATA,
  pptx.shapes.FLOW_CHART_TERMINATOR,
  pptx.shapes.FLOW_CHART_CONNECTOR,
  pptx.shapes.FLOW_CHART_ALTERNATE_PROCESS,
  pptx.shapes.CROSS,
  pptx.shapes.PLUS,
  pptx.shapes.SMILEY_FACE,
  pptx.shapes.NO_SMOKING,
  pptx.shapes.PLAQUE,
  pptx.shapes.CAN,
  pptx.shapes.CUBE,
  pptx.shapes.BEVEL,
  pptx.shapes.DONUT,
  pptx.shapes.CLOUD,
  pptx.shapes.CLOUD_CALLOUT,
  pptx.shapes.HEART,
  pptx.shapes.LIGHTNING_BOLT,
  pptx.shapes.SUN,
  pptx.shapes.MOON,
  pptx.shapes.ARC,
  pptx.shapes.CHORD,
  pptx.shapes.PIE,
];

// Filled shape with text
slide.addShape(pptx.shapes.ROUNDED_RECTANGLE, {
  x: 1, y: 3, w: 4, h: 1.5,
  fill: { color: 'ED7D31' },
  line: { color: 'ED7D31', width: 0 },
  text: 'Click Here',
  options: {
    fontFace: 'Arial',
    fontSize: 18,
    bold: true,
    color: 'FFFFFF',
    align: 'center',
    valign: 'middle',
  }
});
```

### Image Elements

```js
// Add image from file path
slide.addImage({
  path: './images/photo.jpg',
  x: 0.5, y: 0.5, w: 4, h: 3,
  sizing: {
    type: 'contain',   // 'contain'|'cover'|'crop'
    w: 4, h: 3,
  },
  rounding: true,    // circular crop
  opacity: 1,
  rotate: 0,
  shadow: { type: 'outer', color: '000000', opacity: 0.3, blur: 5, offset: 3 },
  border: { pt: 2, color: '666666' },
  hyperlink: { url: 'https://example.com' },
  altText: 'Company logo',
  placeholder: 'body',
});

// Add image from URL
slide.addImage({
  path: 'https://example.com/image.png',
  x: 5, y: 0.5, w: 4, h: 3,
});

// Add image from base64
slide.addImage({
  data: 'data:image/png;base64,iVBORw0KGgo...',
  x: 0.5, y: 4, w: 9, h: 4,
});

// SVG image
slide.addImage({
  data: '<svg>...</svg>',
  type: 'svg',
  x: 1, y: 1, w: 3, h: 3,
});
```

