### Image Elements

```js
// Add image from file path
slide.addImage({
  path: './images/photo.jpg',
  x: 0.5, y: 0.5, w: 4, h: 3,
  sizing: {
    type: 'contain',   // 'contain'|'cover'|'crop'
    w: 4, h: 3,
  },
  rounding: true,    // circular crop
  opacity: 1,
  rotate: 0,
  shadow: { type: 'outer', color: '000000', opacity: 0.3, blur: 5, offset: 3 },
  border: { pt: 2, color: '666666' },
  hyperlink: { url: 'https://example.com' },
  altText: 'Company logo',
  placeholder: 'body',
});

// Add image from URL
slide.addImage({
  path: 'https://example.com/image.png',
  x: 5, y: 0.5, w: 4, h: 3,
});

// Add image from base64
slide.addImage({
  data: 'data:image/png;base64,iVBORw0KGgo...',
  x: 0.5, y: 4, w: 9, h: 4,
});

// SVG image
slide.addImage({
  data: '<svg>...</svg>',
  type: 'svg',
  x: 1, y: 1, w: 3, h: 3,
});
```

