```js
// Video from file
slide.addMedia({
  type: 'video',
  path: './videos/intro.mp4',
  x: 1, y: 1, w: 8, h: 4.5,
  cover: './images/video-thumbnail.jpg',
  autoPlay: false,
  loop: false,
  muted: false,
});

// Audio from URL
slide.addMedia({
  type: 'audio',
  link: 'https://example.com/audio.mp3',
  x: 0.5, y: 0.5, w: 1, h: 0.5,
  autoPlay: false,
  loop: false,
});

// Online video (YouTube embed)
