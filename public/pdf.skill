## pdf-lib — Modifying Existing PDFs

```js
const { PDFDocument, rgb, degrees, StandardFonts } = require('pdf-lib');
const fs = require('fs');

async function modifyPdf() {
  const pdfBytes = fs.readFileSync('input.pdf');
  const pdfDoc = await PDFDocument.load(pdfBytes);

  const pages = pdfDoc.getPages();
  const firstPage = pages[0];
  const { width, height } = firstPage.getSize();

  const font = await pdfDoc.embedFont(StandardFonts.HelveticaBold);

  firstPage.drawText('Added by pdf-lib', {
    x: 50, y: height - 50,
    size: 16,
    font,
    color: rgb(0.12, 0.31, 0.47),
  });

  const savedBytes = await pdfDoc.save();
  fs.writeFileSync('output.pdf', savedBytes);
}
```

### Drawing on Pages (pdf-lib)

```js
const { PDFDocument, rgb, StandardFonts, degrees } = require('pdf-lib');

// Rectangle
page.drawRectangle({ x: 50, y: 100, width: 200, height: 80,
  color: rgb(0.87, 0.93, 0.95), borderColor: rgb(0.12, 0.31, 0.47), borderWidth: 2 });

// Line
page.drawLine({ start: { x: 50, y: 500 }, end: { x: 550, y: 500 },
  thickness: 1, color: rgb(0.8, 0.8, 0.8) });

// Ellipse
page.drawEllipse({ x: 300, y: 300, xScale: 100, yScale: 60,
  color: rgb(0.91, 0.30, 0.24) });

// Rotated text
page.drawText('Watermark', {
  x: 150, y: 300, size: 60,
  font, color: rgb(0.8, 0.8, 0.8),
  opacity: 0.3, rotate: degrees(45),
});
```

### Adding Pages (pdf-lib)

```js
// Add blank page
const page = pdfDoc.addPage([595, 842]);  // A4 in points
const page2 = pdfDoc.insertPage(0);      // insert at position 0

// Copy page from another doc
const donor = await PDFDocument.load(fs.readFileSync('other.pdf'));
const [copiedPage] = await pdfDoc.copyPages(donor, [0]);
pdfDoc.addPage(copiedPage);
```

### Merging PDFs

```js
async function mergePdfs(paths, outputPath) {
  const mergedDoc = await PDFDocument.create();
  for (const p of paths) {
    const doc = await PDFDocument.load(fs.readFileSync(p));
    const pages = await mergedDoc.copyPages(doc, doc.getPageIndices());
    pages.forEach((pg) => mergedDoc.addPage(pg));
  }
  fs.writeFileSync(outputPath, await mergedDoc.save());
}
```

### Embedding Images (pdf-lib)

```js
const pngImage = await pdfDoc.embedPng(fs.readFileSync('logo.png'));
const jpgImage = await pdfDoc.embedJpg(fs.readFileSync('photo.jpg'));

const dims = pngImage.scale(0.5);  // scale by 50%
page.drawImage(pngImage, { x: 50, y: 400, width: dims.width, height: dims.height });
```

### Metadata (pdf-lib)

```js
pdfDoc.setTitle('My Report');
pdfDoc.setAuthor('Dreamcobots');
pdfDoc.setSubject('Quarterly Analysis');
pdfDoc.setKeywords(['report', 'q4', '2024']);
pdfDoc.setProducer('DreamCo Technologies');
pdfDoc.setCreator('pdfkit/pdf-lib');
pdfDoc.setCreationDate(new Date());
pdfDoc.setModificationDate(new Date());
```

---

## Choosing Between PDFKit and pdf-lib

| Feature | PDFKit | pdf-lib |
|---------|--------|---------|
| Create new PDFs | ✅ Best choice | ✅ |
| Modify existing PDFs | ❌ | ✅ Best choice |
| Fill forms | ❌ | ✅ |
| Streaming output | ✅ | ❌ |
| Custom fonts | ✅ | ✅ (with fontkit) |
| Charts/complex layouts | Manual | Manual |
| Merge PDFs | ❌ | ✅ |
