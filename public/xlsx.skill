### ExcelJS Reading Files

```js
// Read xlsx file
const workbook = new ExcelJS.Workbook();
await workbook.xlsx.readFile('data.xlsx');

// Read from stream
const stream = fs.createReadStream('data.xlsx');
await workbook.xlsx.read(stream);

// Read from buffer
const buffer = fs.readFileSync('data.xlsx');
await workbook.xlsx.load(buffer);

// Read csv
await workbook.csv.readFile('data.csv', {
  dateFormats: ['YYYY/MM/DD', 'MM-DD-YYYY'],
  map(value, index) {
    switch (index) {
      case 0: return parseInt(value, 10);
      case 3: return parseFloat(value);
      default: return value;
    }
  },
  sheetName: 'Sheet1',
  encoding: 'utf8',
  parserOptions: {
    delimiter: ',',
    quote: '"',
    escape: '"',
    comment: '#',
    relax: true,
    trim: true,
    skip_empty_lines: true,
    skip_lines_with_error: false,
  }
});

// Iterate worksheets
workbook.eachSheet((worksheet, sheetId) => {
  console.log(`Sheet: ${worksheet.name} (id: ${sheetId})`);
  worksheet.eachRow((row, rowNumber) => {
    console.log(`Row ${rowNumber}:`, row.values.slice(1));
  });
});
```

### ExcelJS Writing Files

```js
// Write xlsx
await workbook.xlsx.writeFile('output.xlsx');

// Write to buffer
const buffer = await workbook.xlsx.writeBuffer();

// Write to stream
const stream = fs.createWriteStream('output.xlsx');
await workbook.xlsx.write(stream);
stream.end();

// Write csv
await workbook.csv.writeFile('output.csv', {
  sheetName: 'Sheet1',
  encoding: 'utf8',
  includeEmptyRows: false,
  dateUTC: false,
  dateFormat: 'YYYY/MM/DD',
  formatterOptions: {
    delimiter: ',',
    quote: '"',
    escape: '"',
    eof: '\n',
  },
  map(value, index) {
    if (value instanceof Date) {
      return value.toISOString().split('T')[0];
    }
    return value;
  }
});
```

### Streaming Large Files (SheetJS)

```js
const XLSX = require('xlsx');

// Stream reading
function readLargeFile(filePath) {
  const workbook = XLSX.readFile(filePath, {
    type: 'file',
    sheetRows: 0,          // 0 = all rows
    cellDates: true,
    cellFormula: false,    // skip formula parsing for speed
    cellHTML: false,       // skip HTML rendering for speed
    bookSheets: false,     // read all sheets
  });
  return workbook;
}

// Process row by row
function processFileStreaming(filePath, sheetName, rowCallback) {
  const workbook = XLSX.readFile(filePath);
  const worksheet = workbook.Sheets[sheetName || workbook.SheetNames[0]];
  const range = XLSX.utils.decode_range(worksheet['!ref']);

  for (let r = range.s.r; r <= range.e.r; r++) {
    const rowData = {};
    for (let c = range.s.c; c <= range.e.c; c++) {
      const cellRef = XLSX.utils.encode_cell({ r, c });
      const cell = worksheet[cellRef];
      if (cell) rowData[XLSX.utils.encode_col(c)] = cell.v;
    }
    rowCallback(rowData, r);
  }
}

// ExcelJS streaming read
const ExcelJS = require('exceljs');

async function streamReadXlsx(filePath) {
  const workbookReader = new ExcelJS.stream.xlsx.WorkbookReader(filePath, {
    entries: 'emit',
    sharedStrings: 'cache',
    hyperlinks: 'cache',
    styles: 'cache',
    worksheets: 'emit',
  });

  workbookReader.on('worksheet', worksheet => {
    worksheet.on('row', row => {
      const values = row.values.slice(1); // remove index 0
      console.log('Row:', values);
    });
    worksheet.on('dimension', dimension => {
      console.log('Dimension:', dimension);
    });
  });

  workbookReader.on('shared-strings', sharedStrings => {
    console.log('Shared strings count:', sharedStrings.count);
  });

  workbookReader.on('end', () => {
    console.log('Done reading');
  });

  await workbookReader.read();
}

// ExcelJS streaming write
async function streamWriteXlsx(outputPath, data) {
  const workbookWriter = new ExcelJS.stream.xlsx.WorkbookWriter({
    filename: outputPath,
    useStyles: true,
    useSharedStrings: true,
  });

  const worksheet = workbookWriter.addWorksheet('Data');
  worksheet.columns = [
    { header: 'ID', key: 'id', width: 10 },
    { header: 'Name', key: 'name', width: 30 },
    { header: 'Value', key: 'value', width: 15 },
  ];

  for (const row of data) {
    await worksheet.addRow(row).commit();
  }

  await worksheet.commit();
  await workbookWriter.commit();
}
```

### Named Ranges and Defined Names

```js
// SheetJS named ranges
const wb = XLSX.utils.book_new();
const ws = XLSX.utils.aoa_to_sheet([['a','b'],['c','d']]);
XLSX.utils.book_append_sheet(wb, ws, 'Sheet1');

// Add named range
wb.Workbook = wb.Workbook || {};
wb.Workbook.Names = wb.Workbook.Names || [];
wb.Workbook.Names.push({
  Name: 'MyRange',
  Ref: 'Sheet1!$A$1:$B$2',
  Comment: 'My named range',
  Hidden: false,
});

// ExcelJS defined names
workbook.definedNames.add('Sheet1!$A$1:$A$10', 'SalesData');
workbook.definedNames.add('Sheet1!$B$1:$B$10', 'ExpenseData');

// Get defined name
const name = workbook.definedNames.getMatrix('SalesData');
console.log(name);

// Remove defined name
workbook.definedNames.remove('SalesData');

// List all defined names
workbook.definedNames.model.forEach(([name, refStr]) => {
  console.log(`${name}: ${refStr}`);
});
```

### Pivot Table Patterns

```js
// Create pivot-like summary using SheetJS
function createPivotSummary(data, rowField, colField, valueField) {
  // Collect unique row and column values
  const rows = [...new Set(data.map(d => d[rowField]))].sort();
  const cols = [...new Set(data.map(d => d[colField]))].sort();

  // Build summary matrix
  const matrix = [['', ...cols, 'Total']];

  for (const row of rows) {
    const rowData = [row];
    let rowTotal = 0;

    for (const col of cols) {
      const val = data
        .filter(d => d[rowField] === row && d[colField] === col)
        .reduce((sum, d) => sum + (d[valueField] || 0), 0);
      rowData.push(val);
      rowTotal += val;
    }

    rowData.push(rowTotal);
    matrix.push(rowData);
  }

  // Add grand total row
  const totals = ['Grand Total'];
  let grandTotal = 0;
  for (let c = 1; c <= cols.length; c++) {
    const colTotal = matrix.slice(1).reduce((sum, r) => sum + (r[c] || 0), 0);
    totals.push(colTotal);
    grandTotal += colTotal;
  }
  totals.push(grandTotal);
  matrix.push(totals);

  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet(matrix);
  XLSX.utils.book_append_sheet(wb, ws, 'Pivot');
  return wb;
}
```

### CSV and TSV Processing

```js
// Parse CSV with SheetJS
function parseCSV(csvString, options = {}) {
  const wb = XLSX.read(csvString, {
    type: 'string',
    raw: false,
    ...options,
  });
  return XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
}

// Generate CSV from data
function generateCSV(data, fields) {
  const ws = XLSX.utils.json_to_sheet(data, { header: fields });
  return XLSX.utils.sheet_to_csv(ws);
}

// Handle large CSV files
const fs = require('fs');
const readline = require('readline');

async function processLargeCSV(filePath, processRow) {
  const stream = fs.createReadStream(filePath);
  const rl = readline.createInterface({ input: stream, crlfDelay: Infinity });

  let headers = null;
  let rowNum = 0;

  for await (const line of rl) {
    if (!headers) {
      headers = line.split(',').map(h => h.trim().replace(/"/g, ''));
    } else {
      const values = line.split(',');
      const row = {};
      headers.forEach((h, i) => { row[h] = values[i]?.trim().replace(/"/g, ''); });
      await processRow(row, ++rowNum);
    }
  }

  return rowNum;
}
```

### Complete Reporting Example

```js
const XLSX = require('xlsx');
const ExcelJS = require('exceljs');

async function generateSalesReport(salesData, outputPath) {
  const wb = new ExcelJS.Workbook();
  wb.creator = 'Sales Analytics';
  wb.created = new Date();

  // Summary sheet
  const summary = wb.addWorksheet('Summary', {
    properties: { tabColor: { argb: 'FF4472C4' } },
  });

  summary.columns = [
    { header: 'Metric', key: 'metric', width: 30 },
    { header: 'Value', key: 'value', width: 20 },
    { header: 'Change', key: 'change', width: 15 },
  ];

  // Style header row
  summary.getRow(1).font = { bold: true, size: 12, color: { argb: 'FFFFFFFF' } };
  summary.getRow(1).fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF4472C4' } };

  // Add summary rows
  const metrics = [
    { metric: 'Total Revenue', value: salesData.totalRevenue, change: '+12.5%' },
    { metric: 'Total Orders', value: salesData.totalOrders, change: '+8.3%' },
    { metric: 'Avg Order Value', value: salesData.avgOrderValue, change: '+3.8%' },
    { metric: 'New Customers', value: salesData.newCustomers, change: '+15.2%' },
    { metric: 'Repeat Rate', value: salesData.repeatRate + '%', change: '+2.1%' },
  ];

  metrics.forEach(m => {
    const row = summary.addRow(m);
    row.getCell('value').numFmt = typeof m.value === 'number' ? '"$"#,##0.00' : '@';
  });

  // Detail sheet
  const detail = wb.addWorksheet('Sales Detail');
  detail.columns = [
    { header: 'Date', key: 'date', width: 15 },
    { header: 'Product', key: 'product', width: 25 },
    { header: 'Qty', key: 'qty', width: 10 },
    { header: 'Unit Price', key: 'unitPrice', width: 15 },
    { header: 'Total', key: 'total', width: 15 },
    { header: 'Sales Rep', key: 'rep', width: 20 },
    { header: 'Region', key: 'region', width: 15 },
  ];

  salesData.items.forEach(item => {
    const row = detail.addRow(item);
    row.getCell('date').numFmt = 'yyyy-mm-dd';
    row.getCell('unitPrice').numFmt = '"$"#,##0.00';
    row.getCell('total').numFmt = '"$"#,##0.00';
  });

  // Add chart
  const chart = detail.addChart('column', {
    title: { name: 'Sales by Region' },
    legend: { position: 'b' },
    plotArea: {
      catAxis: { title: { name: 'Region' } },
      valAxis: { title: { name: 'Revenue ($)' } },
    },
    tl: { col: 0, row: detail.rowCount + 2 },
    br: { col: 7, row: detail.rowCount + 20 },
  });

  await wb.xlsx.writeFile(outputPath);
  return outputPath;
}
```

### Troubleshooting Guide

**Issue: Dates showing as numbers**
```js
// Solution: Enable cellDates option
const wb = XLSX.readFile('file.xlsx', { cellDates: true });
// Or convert manually
function excelDateToJsDate(serial) {
  const utc_days = Math.floor(serial - 25569);
  const utc_value = utc_days * 86400;
  return new Date(utc_value * 1000);
}
```

**Issue: Formula cells showing old values**
```js
// Solution: Force recalculation
workbook.calcProperties.fullCalcOnLoad = true;
// Or clear cached formula results
worksheet.eachRow(row => {
  row.eachCell(cell => {
    if (cell.type === ExcelJS.ValueType.Formula) {
      cell.value = { formula: cell.formula }; // remove cached result
    }
  });
});
```

**Issue: Large file memory issues**
```js
// Solution: Use streaming API
const workbookWriter = new ExcelJS.stream.xlsx.WorkbookWriter({
  filename: 'large-output.xlsx',
  useStyles: true,
  useSharedStrings: false, // disable for performance
});
```

**Issue: Chinese/Japanese/Korean characters garbled in CSV**
```js
// Solution: Use UTF-8 BOM
const csv = XLSX.utils.sheet_to_csv(ws);
const bom = '\uFEFF'; // UTF-8 BOM
fs.writeFileSync('output.csv', bom + csv, 'utf8');
```

**Issue: Cell styles not preserved**
```js
// Solution: Enable cellStyles when reading
const wb = XLSX.read(data, { type: 'buffer', cellStyles: true });
// Or when writing with ExcelJS, explicitly set styles on each cell
```


---

## SheetJS (xlsx) Complete API Reference

### Installation

```bash
npm install xlsx
# or
yarn add xlsx
# or with ExcelJS
npm install exceljs
```

### Core Reading API

```js
const XLSX = require('xlsx');

// Read from file path
const wb = XLSX.readFile('spreadsheet.xlsx', {
  type: 'file',
  cellDates: true,
  cellFormula: true,
  cellNF: true,
  cellStyles: true,
  sheetStubs: false,
  bookSheets: false,
  bookDeps: false,
  bookFiles: false,
  bookVBA: false,
  password: '',
  WTF: false,
  dense: false,
  nodim: false,
  PRN: false,
  UTC: false,
});

// Read from Buffer
const buf = fs.readFileSync('data.xlsx');
const wb2 = XLSX.read(buf, { type: 'buffer' });

// Read from base64 string
const b64 = fs.readFileSync('data.xlsx', 'base64');
const wb3 = XLSX.read(b64, { type: 'base64' });

// Read from array of bytes
const arr = new Uint8Array(fs.readFileSync('data.xlsx'));
const wb4 = XLSX.read(arr, { type: 'array' });

// Read from binary string
const bstr = fs.readFileSync('data.xlsx', 'binary');
const wb5 = XLSX.read(bstr, { type: 'binary' });
```

### Workbook Object Structure

```js
// Workbook structure
const workbook = {
  SheetNames: ['Sheet1', 'Sheet2'],  // Ordered list of sheet names
  Sheets: {
    'Sheet1': { /* worksheet object */ },
    'Sheet2': { /* worksheet object */ }
  },
  Props: {
    Author: 'John Doe',
    Title: 'My Spreadsheet',
    Subject: 'Data Analysis',
    CreatedDate: new Date(),
    ModifiedDate: new Date(),
    Category: 'Finance',
    Keywords: 'budget, finance',
    Description: 'Annual budget spreadsheet',
    LastAuthor: 'Jane Doe',
    Company: 'ACME Corp',
    Manager: 'Bob Smith'
  },
  Custprops: {},
  Calcchain: null,
  Workbook: {
    Names: [],
    Views: [{ RTL: false }],
    WBProps: {
      date1904: false,
      defaultThemeVersion: 124226
    }
  }
};
```

### Worksheet Object Structure

```js
// Worksheet structure
const worksheet = {
  '!ref': 'A1:Z100',         // cell range
  '!margins': {              // page margins
    left: 0.7,
    right: 0.7,
    top: 0.75,
    bottom: 0.75,
    header: 0.3,
    footer: 0.3
  },
  '!cols': [                 // column info array
    { wch: 20 },             // width in characters
    { wpx: 150 },            // width in pixels
    { hidden: true }         // hidden column
  ],
  '!rows': [                 // row info array
    { hpt: 20 },             // height in points
    { hpx: 27 },             // height in pixels
    { hidden: false }
  ],
  '!merges': [               // merged cell ranges
    { s: { r: 0, c: 0 }, e: { r: 0, c: 3 } }
  ],
  '!protect': {              // worksheet protection
    password: 'secret',
    selectLockedCells: true,
    selectUnlockedCells: true,
    formatCells: false,
    formatColumns: false,
    formatRows: false,
    insertColumns: false,
    insertRows: false,
    insertHyperlinks: false,
    deleteColumns: false,
    deleteRows: false,
    sort: false,
    autoFilter: false,
    pivotTables: false
  },
  '!autofilter': { ref: 'A1:F1' },
  'A1': { t: 's', v: 'Name', w: 'Name' },
  'B1': { t: 's', v: 'Age' },
  'A2': { t: 's', v: 'Alice' },
  'B2': { t: 'n', v: 30, w: '30' }
};
```

### Cell Object Reference

```js
// Cell object properties
const cell = {
  t: 'n',          // type: 'b'=bool, 'n'=num, 's'=str, 'd'=date, 'e'=err, 'z'=stub
  v: 42,           // raw value
  w: '42',         // formatted text
  f: 'SUM(A1:A10)',// formula
  F: 'A1:A10',     // array formula range
  r: '<t>42</t>',  // rich text
  h: '42',         // HTML rendering
  c: [             // comments
    { a: 'Author', t: 'comment text', T: false }
  ],
  z: '#,##0.00',   // number format string
  l: {             // hyperlink
    Target: 'https://example.com',
    Tooltip: 'Visit site'
  },
  s: {             // style object
    font: { name: 'Arial', sz: 12, bold: true, color: { rgb: 'FF0000' } },
    fill: { patternType: 'solid', fgColor: { rgb: 'FFFFCC' } },
    border: {
      top: { style: 'thin', color: { auto: 1 } },
      bottom: { style: 'thin', color: { auto: 1 } },
      left: { style: 'thin', color: { auto: 1 } },
      right: { style: 'thin', color: { auto: 1 } }
    },
    alignment: {
      horizontal: 'center',
      vertical: 'middle',
      wrapText: true,
      indent: 0,
      readingOrder: 0,
      textRotation: 0,
      shrinkToFit: false
    },
    numFmt: '0.00%'
  }
};
```

### Writing Files

```js
// Write to file
XLSX.writeFile(workbook, 'output.xlsx', {
  bookType: 'xlsx',        // 'xlsx'|'xlsm'|'xlsb'|'xls'|'csv'|'txt'|'sylk'|'html'|'dif'|'dbf'|'prn'|'ods'
  type: 'file',
  compression: true,       // zip compression
  Props: { Author: 'Me' },
  bookSST: false,          // use shared string table
  bookVBA: false,
  cellDates: false,        // write dates as date types
  cellStyles: false,       // write styles
  numbers: XLSX.SSF._table,
  sheet: 'Sheet1',         // for single-sheet formats
});

// Write to buffer
const wbuf = XLSX.write(workbook, { bookType: 'xlsx', type: 'buffer' });

// Write to base64
const wb64 = XLSX.write(workbook, { bookType: 'xlsx', type: 'base64' });

// Write to binary string
const wbin = XLSX.write(workbook, { bookType: 'xlsx', type: 'binary' });

// Write to array
const warr = XLSX.write(workbook, { bookType: 'xlsx', type: 'array' });
```

### Sheet Operations

```js
// Access sheets
const sheet = workbook.Sheets[workbook.SheetNames[0]];

// Add a new sheet
const newSheet = XLSX.utils.aoa_to_sheet([
  ['Name', 'Age', 'Score'],
  ['Alice', 30, 95.5],
  ['Bob', 25, 87.3],
  ['Charlie', 35, 91.0],
]);
XLSX.utils.book_append_sheet(workbook, newSheet, 'People');

// Delete a sheet
const idx = workbook.SheetNames.indexOf('OldSheet');
if (idx !== -1) {
  workbook.SheetNames.splice(idx, 1);
  delete workbook.Sheets['OldSheet'];
}

// Copy a sheet
function copySheet(wb, fromName, toName) {
  const srcSheet = wb.Sheets[fromName];
  const destSheet = JSON.parse(JSON.stringify(srcSheet));
  XLSX.utils.book_append_sheet(wb, destSheet, toName);
}
```

### Data Conversion Utilities

```js
// Array of arrays to worksheet
const aoaData = [
  ['ID', 'Product', 'Qty', 'Price', 'Total'],
  [1, 'Widget A', 10, 9.99, 99.90],
  [2, 'Widget B', 5, 14.99, 74.95],
  [3, 'Gadget X', 3, 29.99, 89.97],
];
const ws1 = XLSX.utils.aoa_to_sheet(aoaData, {
  header: [],           // custom header row
  skipHeader: false,    // skip header
  origin: 'A1',         // starting cell
  dateNF: 'yyyy-mm-dd', // date format
  cellDates: true,      // output dates as Date objects
  dense: false,         // use dense format
  sheetRows: 100,       // max rows to read
});

// Array of objects to worksheet
const aooData = [
  { name: 'Alice', dept: 'Engineering', salary: 95000 },
  { name: 'Bob', dept: 'Marketing', salary: 72000 },
  { name: 'Charlie', dept: 'Sales', salary: 68000 },
];
const ws2 = XLSX.utils.json_to_sheet(aooData, {
  header: ['name', 'dept', 'salary'],  // key order
  skipHeader: false,
  origin: { r: 1, c: 0 },
  dateNF: 'yyyy-mm-dd',
});

// Worksheet to array of arrays
const aoa = XLSX.utils.sheet_to_aoa(worksheet, {
  header: 1,           // 1 = return arrays, 'A' = use column letters
  defval: null,        // default value for empty cells
  blankrows: false,    // include blank rows
  range: 'A1:D10',     // only this range
  raw: true,           // return raw values
  rawNumbers: false,   // return raw number values
  dateNF: 'yyyy-mm-dd',
});

// Worksheet to array of objects
const aoo = XLSX.utils.sheet_to_json(worksheet, {
  header: 1,           // use row 1 as header
  defval: '',
  blankrows: false,
  range: 1,            // start from row index 1
  raw: false,
});

// Worksheet to CSV
const csv = XLSX.utils.sheet_to_csv(worksheet, {
  FS: ',',             // field separator
  RS: '\n',            // row separator
  dateNF: 'yyyy-mm-dd',
  strip: false,        // strip trailing whitespace
  blankrows: true,
  skipHidden: false,
});

// Worksheet to HTML
const html = XLSX.utils.sheet_to_html(worksheet, {
  id: 'table1',
  editable: false,
  header: '',
  footer: '',
});

// Worksheet to formula text
const txt = XLSX.utils.sheet_to_formulae(worksheet);
```

### Cell Range Operations

```js
// Encode/decode cell addresses
const addr = XLSX.utils.encode_cell({ r: 0, c: 0 }); // 'A1'
const cell2 = XLSX.utils.decode_cell('A1');            // {r:0, c:0}
const col = XLSX.utils.encode_col(0);                  // 'A'
const row = XLSX.utils.encode_row(0);                  // '1'
const range = XLSX.utils.encode_range({ s:{r:0,c:0}, e:{r:9,c:4} }); // 'A1:E10'
const rangeObj = XLSX.utils.decode_range('A1:E10'); // {s:{r:0,c:0}, e:{r:9,c:4}}

// Update worksheet range
function updateSheetRange(ws) {
  const range = XLSX.utils.decode_range(ws['!ref']);
  // iterate over cells
  for (let r = range.s.r; r <= range.e.r; r++) {
    for (let c = range.s.c; c <= range.e.c; c++) {
      const cellRef = XLSX.utils.encode_cell({ r, c });
      const cell = ws[cellRef];
      if (!cell) continue;
      // process cell
    }
  }
}

// Set cell value
function setCellValue(ws, cellRef, value, type) {
  const cell = ws[cellRef] || (ws[cellRef] = {});
  cell.v = value;
  cell.t = type || (typeof value === 'number' ? 'n' : 's');
  if (typeof value === 'boolean') cell.t = 'b';
  if (value instanceof Date) cell.t = 'd';
}
```

