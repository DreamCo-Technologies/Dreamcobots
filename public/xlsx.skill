    { hidden: true }         // hidden column
  ],
  '!rows': [                 // row info array
    { hpt: 20 },             // height in points
    { hpx: 27 },             // height in pixels
    { hidden: false }
  ],
  '!merges': [               // merged cell ranges
    { s: { r: 0, c: 0 }, e: { r: 0, c: 3 } }
  ],
  '!protect': {              // worksheet protection
    password: 'secret',
    selectLockedCells: true,
    selectUnlockedCells: true,
    formatCells: false,
    formatColumns: false,
    formatRows: false,
    insertColumns: false,
    insertRows: false,
    insertHyperlinks: false,
    deleteColumns: false,
    deleteRows: false,
    sort: false,
    autoFilter: false,
    pivotTables: false
  },
  '!autofilter': { ref: 'A1:F1' },
  'A1': { t: 's', v: 'Name', w: 'Name' },
  'B1': { t: 's', v: 'Age' },
  'A2': { t: 's', v: 'Alice' },
