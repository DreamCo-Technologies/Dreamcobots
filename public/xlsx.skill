});

// Contains text
worksheet.addConditionalFormatting({
  ref: 'A2:A100',
  rules: [
    {
      type: 'containsText',
      operator: 'containsText',
      text: 'URGENT',
      priority: 1,
      style: {
        font: { bold: true, color: { argb: 'FF9C0006' } },
        fill: { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFFC7CE' } },
      }
    }
  ]
});
