      operator: 'greaterThan',
      formulae: [100],
      priority: 1,
      style: {
        font: { bold: true, color: { argb: 'FF006100' } },
        fill: { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFC6EFCE' } },
      }
    }
