{
  "name": "dreamcobots",
  "version": "1.0.0",
  "description": "DreamCobots — Autonomous Money Operating System: AI-powered bots for lead generation, real estate, crypto, and more.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "mkdir -p dist && cp -r public/* dist/",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --passWithNoTests",
    "test:buddy": "node automation-tools/agents/buddy-connectivity-test.js",
    "check:bot-framework": "python3 tools/check_bot_framework.py",
    "generate:bot-specializations": "python3 tools/generate_bot_specializations.py",
    "check:bot-specializations": "python3 tools/generate_bot_specializations.py --check",
    "generate:system-libraries": "python3 tools/generate_system_libraries.py",
    "check:system-libraries": "python3 tools/generate_system_libraries.py --check",
    "scan:github-patterns": "python3 tools/github_pattern_scanner.py",
    "generate:buddy-inventory": "python3 tools/generate_buddy_capability_inventory.py",
    "generate:buddy-productivity": "python3 tools/generate_buddy_productivity_tracker.py",
    "generate:high-risk-approvals": "python3 tools/generate_high_risk_approval_registry.py",
    "generate:production-approval-packets": "python3 tools/generate_production_approval_packets.py",
    "approve:high-risk-bot": "python3 tools/approve_high_risk_bot.py",
    "check:production-readiness": "python3 tools/generate_buddy_capability_inventory.py --strict-production-ready",
    "scan:github-triage": "python3 tools/generate_github_triage_report.py",
    "check:github-triage": "python3 tools/generate_github_triage_report.py --strict",
    "steward:repo": "python3 tools/repository_steward.py",
    "check:repo-cleanroom": "python3 tools/repository_steward.py --strict",
    "report:release-readiness": "python3 tools/generate_dreamco_release_readiness.py",
    "check:release-readiness": "python3 tools/generate_dreamco_release_readiness.py --strict",
    "report:app-foundry": "python3 tools/generate_app_foundry_readiness.py",
    "check:app-foundry": "python3 tools/generate_app_foundry_readiness.py --check",
    "report:app-category-catalog": "python3 tools/generate_app_category_catalog.py",
    "check:app-category-catalog": "python3 tools/generate_app_category_catalog.py --check",
    "report:bot-founder-store": "python3 tools/generate_bot_founder_app_store.py",
    "check:bot-founder-store": "python3 tools/generate_bot_founder_app_store.py --check",
    "report:24-hour-scaling": "python3 tools/generate_24_hour_scaling_report.py",
    "check:24-hour-scaling": "python3 tools/generate_24_hour_scaling_report.py --check",
    "report:buddy-24-hour-package": "python3 tools/generate_buddy_24_hour_client_package.py",
    "check:buddy-24-hour-package": "python3 tools/generate_buddy_24_hour_client_package.py --check",
    "report:revenue-practice": "python3 tools/generate_bot_autonomous_revenue_practice.py",
    "check:revenue-practice": "python3 tools/generate_bot_autonomous_revenue_practice.py --check",
    "report:specialized-knowledge": "python3 tools/generate_specialized_bot_knowledge.py",
    "check:specialized-knowledge": "python3 tools/generate_specialized_bot_knowledge.py --check",
    "report:ai-agent-model-library": "python3 tools/generate_buddy_ai_agent_model_library.py",
    "check:ai-agent-model-library": "python3 tools/generate_buddy_ai_agent_model_library.py --check",
    "report:business-launch-expansion": "python3 tools/generate_business_launch_expansion_report.py",
    "check:business-launch-expansion": "python3 tools/generate_business_launch_expansion_report.py --check",
    "report:contract-discovery": "python3 tools/generate_bot_contract_discovery_report.py",
    "check:contract-discovery": "python3 tools/generate_bot_contract_discovery_report.py --check",
    "report:ai-data-packages": "python3 tools/generate_ai_data_package_library.py",
    "check:ai-data-packages": "python3 tools/generate_ai_data_package_library.py --check",
    "report:people-job-qualification": "python3 tools/generate_people_job_qualification_report.py",
    "check:people-job-qualification": "python3 tools/generate_people_job_qualification_report.py --check",
    "report:bot-owner-settings": "python3 tools/generate_bot_owner_settings_report.py",
    "check:bot-owner-settings": "python3 tools/generate_bot_owner_settings_report.py --check",
    "report:storage": "python3 tools/storage_guard.py",
    "check:storage": "python3 tools/storage_guard.py --strict",
    "report:stripe-rescue": "python3 tools/stripe_revenue_rescue.py",
    "report:stripe-builder": "python3 tools/generate_stripe_builder_bot.py",
    "check:stripe-builder": "python3 tools/generate_stripe_builder_bot.py --check",
    "report:stripe-prices": "python3 tools/generate_stripe_price_audit.py",
    "check:stripe-prices": "python3 tools/generate_stripe_price_audit.py --check",
    "report:google-cloud": "python3 tools/generate_google_cloud_readiness.py",
    "check:google-cloud": "python3 tools/generate_google_cloud_readiness.py --check",
    "check:buddy-bot-connections": "python3 tools/buddy_bot_connection_guard.py",
    "codeout:bots": "python3 tools/code_out_bot_runtimes.py && python3 tools/generate_buddy_capability_inventory.py",
    "test:generated-bots": "python3 tools/run_generated_bot_smoke.py",
    "build:hostinger:buddy": "cd dreamco-control-tower/frontend && npm ci && VITE_START_TAB=command-center npm run build",
    "scan:missing": "node automation-tools/agents/dreamco-missing-files-scan.js",
    "scan:missing:strict": "node automation-tools/agents/dreamco-missing-files-scan.js --strict",
    "scan:dependencies": "node automation-tools/agents/dependency-audit.js",
    "scan:dependencies:strict": "node automation-tools/agents/dependency-audit.js --strict",
    "scan:local-imports": "python3 tools/local_import_audit.py",
    "scan:local-imports:strict": "python3 tools/local_import_audit.py --check",
    "scan:issues": "node automation-tools/agents/issue-goal-coverage.js",
    "scan:issues:strict": "node automation-tools/agents/issue-goal-coverage.js --strict",
    "autonomous:readiness": "node automation-tools/agents/autonomous-readiness-audit.js",
    "autonomous:readiness:strict": "node automation-tools/agents/autonomous-readiness-audit.js --strict",
    "sandbox:no-hallucinations": "node automation-tools/agents/sandbox-hallucination-audit.js",
    "sandbox:no-hallucinations:strict": "node automation-tools/agents/sandbox-hallucination-audit.js --strict",
    "repair:bot-metadata": "node automation-tools/agents/repair-bot-metadata.js",
    "repair:bot-metadata:apply": "node automation-tools/agents/repair-bot-metadata.js --apply",
    "debug:all": "npm run scan:dependencies && npm run scan:local-imports && npm run scan:issues && npm run autonomous:readiness && npm run repair:bot-metadata && npm run scan:missing && npm run sandbox:no-hallucinations && npm run test:buddy",
    "audit:agents": "node automation-tools/agents/agent-audit.js",
    "lint": "eslint . --ext .js --max-warnings=0",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "apply-fix": "node apply-fix.js",
    "diagnose": "node diagnose.js",
    "deploy": "node deploy.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DreamCo-Technologies/Dreamcobots.git"
  },
  "author": "Irean Jordan",
  "license": "ISC",
  "dependencies": {
    "@langchain/core": "^1.0.0",
    "docx": "^9.6.1",
    "dotenv": "^17.4.1",
    "express": "^4.17.1",
    "langchain": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.0.0",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  }
}
