{
  "version": "1.1.0",
  "purpose": "Central on/off switchboard for Buddy tools, MCP connectors, GitHub capabilities, web search, social drafts, occupational bots, sales workflows, and command permissions.",
  "defaultMode": "supervised",
  "tools": [
    {
      "id": "github_repository_read",
      "name": "GitHub Repository Read",
      "category": "github",
      "enabled": true,
      "risk": "low",
      "capabilities": ["read_files", "search_code", "inspect_branches", "inspect_prs", "inspect_issues"],
      "requiresApproval": false
    },
    {
      "id": "github_repository_write",
      "name": "GitHub Repository Write",
      "category": "github",
      "enabled": true,
      "risk": "medium",
      "capabilities": ["create_files", "update_files", "create_branches", "open_pull_requests"],
      "requiresApproval": true
    },
    {
      "id": "github_actions_dispatch",
      "name": "GitHub Actions Dispatch",
      "category": "github",
      "enabled": true,
      "risk": "medium",
      "capabilities": ["run_scans", "run_tests", "generate_reports", "repair_metadata_pr"],
      "requiresApproval": true
    },
    {
      "id": "stripe_revenue_tracking",
      "name": "Stripe Revenue Tracking",
      "category": "money",
      "enabled": true,
      "risk": "high",
      "capabilities": ["read_revenue_reports", "track_webhook_events", "attribute_revenue_to_bots"],
      "requiresApproval": true
    },
    {
      "id": "web_research_public_sources",
      "name": "Public Web Research",
      "category": "research",
      "enabled": true,
      "risk": "medium",
      "capabilities": ["find_public_data", "research_clients", "compare_competitors", "collect_source_links"],
      "requiresApproval": false,
      "policy": "Use public sources, obey site terms, do not scrape private data, do not spam prospects."
    },
    {
      "id": "client_discovery",
      "name": "Client Discovery",
      "category": "sales",
      "enabled": true,
      "risk": "medium",
      "capabilities": ["identify_customer_segments", "score_fit", "draft_outreach", "log_leads"],
      "requiresApproval": true,
      "policy": "Human approval required before contacting prospects."
    },
    {
      "id": "social_media_draft_studio",
      "name": "Social Media Draft Studio",
      "category": "marketing",
      "enabled": true,
      "risk": "medium",
      "capabilities": ["draft_posts", "content_calendar", "campaign_briefs", "social_metrics_review"],
      "requiresApproval": true,
      "policy": "Draft-only by default. Posting, commenting, messaging, and ad spend require approval and platform secrets."
    },
    {
      "id": "occupational_worker_registry",
      "name": "Occupational Worker Registry",
      "category": "occupational_bots",
      "enabled": true,
      "risk": "low",
      "capabilities": ["map_job_families", "identify_efficiency_workflows", "assign_worker_bots", "generate_training_paths"],
      "requiresApproval": false
    },
    {
      "id": "tool_finder_bot",
      "name": "Tool Finder Bot",
      "category": "tool_discovery",
      "enabled": true,
      "risk": "medium",
      "capabilities": ["search_github", "search_official_docs", "search_package_registries", "score_tools", "write_tool_reports"],
      "requiresApproval": false,
      "policy": "May research public sources. Installing dependencies, cloning private repos, or publishing tools requires approval."
    },
    {
      "id": "skill_finder_bot",
      "name": "Skill Finder Bot",
      "category": "learning",
      "enabled": true,
      "risk": "medium",
      "capabilities": ["search_wikipedia", "search_official_docs", "build_playbooks", "write_memory_records", "design_practice_tasks"],
      "requiresApproval": false,
      "policy": "Every learned skill must include a source, confidence score, usable summary, and next experiment."
    },
    {
      "id": "local_command_check",
      "name": "Local Check Commands",
      "category": "commands",
      "enabled": true,
      "risk": "low",
      "capabilities": ["scan_missing_files", "dependency_audit", "issue_goal_coverage", "autonomous_readiness", "generate_reports"],
      "requiresApproval": false
    },
    {
      "id": "local_command_write",
      "name": "Local Write Commands",
      "category": "commands",
      "enabled": false,
      "risk": "high",
      "capabilities": ["mass_generate_files", "rewrite_dashboards", "apply_repairs"],
      "requiresApproval": true
    },
    {
      "id": "external_builder",
      "name": "External Builder",
      "category": "external_builder",
      "enabled": false,
      "risk": "high",
      "capabilities": ["external_repo_rebuild", "code_generation"],
      "requiresApproval": true,
      "connectionStatus": "not_visible_to_codex_session",
      "notes": "Enable only after its GitHub username/app, branch, or PR is verified against DreamCo-Technologies/Dreamcobots."
    }
  ],
  "modeToggles": ["observe", "diagnose", "draft", "build", "test", "command", "autopilot", "locked"],
  "approvalRules": [
    "Money movement, Stripe writes, prospect outreach, deploys, social posting, ad spend, and mass file generation require owner approval.",
    "Read-only research, draft creation, memory curation, and report generation may run automatically.",
    "Every tool run must write an event to the dashboard tracking layer.",
    "Every learning or tool recommendation must include source, confidence, and next experiment."
  ]
}
