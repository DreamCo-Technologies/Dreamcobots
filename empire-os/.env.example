# =============================================================
#  DreamCo Empire OS — Environment Variables
#  
#  INSTRUCTIONS:
#  1. Copy this file:  cp .env.example .env
#  2. Fill in YOUR values in the .env file
#  3. NEVER commit .env to GitHub — only .env.example is safe
#  4. For GitHub Actions, add these as GitHub Secrets:
#     Repo → Settings → Secrets and variables → Actions → New secret
# =============================================================

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dreamco_empire_os

# ── OPENAI / AI ───────────────────────────────────────────────
# OpenAI API Key — powers all 1,051 bots
# Get at: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-proj-...your-key-here...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── STRIPE PAYMENTS ───────────────────────────────────────────
# Get LIVE keys at: https://dashboard.stripe.com/apikeys
# (Switch to "Live mode" — NOT test mode)
STRIPE_LIVE_SECRET_KEY=sk_live_...your-live-secret-key...
STRIPE_LIVE_PK=pk_live_...your-live-publishable-key...

# Stripe Webhook Secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...your-webhook-secret...

# ── GITHUB ────────────────────────────────────────────────────
# Personal Access Token for pushing bots to DreamCo-Technologies/Dreamcobots
# Create at: https://github.com/settings/tokens/new
# Required scope: repo (full control)
# Token starts with: ghp_...
GITHUB_TOKEN=ghp_...your-token-here...

# ── SERVER ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── DREAMCO-SPECIFIC (configured for DreamCo cloud, leave blank locally, leave blank locally) ─
# These are automatically provided when running in DreamCo cloud
DREAMCO_DOMAINS=
REPL_IDENTITY=
DREAMCO_CONNECTORS_HOSTNAME=
DREAMCO_DEPLOYMENT=
WEB_REPL_RENEWAL=
