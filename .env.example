# =============================================================
#  DreamCo Empire OS — Environment Variables
#  
#  INSTRUCTIONS:
#  1. Copy this file:  cp .env.example .env
#  2. Fill in YOUR values in the .env file
#  3. NEVER commit .env to GitHub — only .env.example is safe
#  4. For GitHub Actions, add these as GitHub Secrets:
#     Repo → Settings → Secrets and variables → Actions → New secret
# =============================================================

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dreamco_empire_os

# ── OPENAI / AI ───────────────────────────────────────────────
# Optional hosted model key. Buddy's governed fleet runtime and local tools do
# not require it; configured model routes can use it for generated responses.
# Get at: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-proj-...your-key-here...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── STRIPE PAYMENTS ───────────────────────────────────────────
# Get LIVE keys at: https://dashboard.stripe.com/apikeys
# (Switch to "Live mode" — NOT test mode)
STRIPE_LIVE_SECRET_KEY=sk_live_...your-live-secret-key...
STRIPE_LIVE_PK=pk_live_...your-live-publishable-key...

# Stripe Webhook Secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...your-webhook-secret...

# ── GITHUB ────────────────────────────────────────────────────
# Personal Access Token for pushing bots to DreamCo-Technologies/Dreamcobots
# Create at: https://github.com/settings/tokens/new
# Prefer a fine-grained token limited to this repository and Contents write.
# Token starts with: ghp_...
GITHUB_TOKEN=ghp_...your-token-here...

# GitHub writes are off by default and always target a review branch.
BUDDY_GITHUB_SYNC_ENABLED=false
BUDDY_GITHUB_SYNC_BRANCH=buddy/automated-updates

# ── OWNER APPROVAL NOTIFICATIONS ─────────────────────────────
# Optional HTTPS adapters. In-app approvals work without these services.
BUDDY_EMAIL_WEBHOOK_URL=https://notifications.example.com/email
BUDDY_SMS_WEBHOOK_URL=https://notifications.example.com/sms
BUDDY_VOICE_CALL_WEBHOOK_URL=https://notifications.example.com/voice
BUDDY_SOCIAL_WEBHOOK_URL=https://social.example.com/publish

# Store adapter credentials only as deployment secrets. Code refers to the
# secret by environment-variable name and never writes the value to profiles.
BUDDY_NOTIFICATION_WEBHOOK_SECRET=replace-with-deployment-secret
BUDDY_SOCIAL_WEBHOOK_SECRET=replace-with-deployment-secret

# ── SERVER ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
