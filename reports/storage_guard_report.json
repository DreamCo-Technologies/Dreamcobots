  "useful_data_policy": {
    "rule": "Only store data that can improve owner decisions, client delivery, bot learning, debugging, compliance, or reproducible rebuilds.",
    "keep_categories": [
      "approved_user_preferences",
      "active_task_context",
      "tested_skill_lessons",
